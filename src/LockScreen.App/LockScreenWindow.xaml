<Window x:Class="LockScreen.App.LockScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lock Screen"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#0B1020"
        KeyDown="OnWindowKeyDown">
    <Grid Margin="36">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#09111F" Offset="0" />
                <GradientStop Color="#142544" Offset="0.55" />
                <GradientStop Color="#1E3A5F" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="460"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#CC0F172A"
                CornerRadius="20">
            <StackPanel>
                <TextBlock Text="Personal Lock Screen"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Margin="0,12,0,0"
                           Text="按 Ctrl+Alt+L 进入此界面。MVP 使用本地 PIN 解锁。"
                           Foreground="#C7D2FE"
                           FontSize="15"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,28,0,0"
                           Text="当前默认 PIN"
                           Foreground="#93C5FD"
                           FontSize="13" />
                <TextBlock Margin="0,6,0,0"
                           Text="1234"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold" />
                <PasswordBox x:Name="PinInput"
                             Margin="0,28,0,0"
                             Height="44"
                             FontSize="20"
                             VerticalContentAlignment="Center"
                             PasswordChar="●"
                             PasswordChanged="OnPasswordChanged" />
                <TextBlock x:Name="HintText"
                           Margin="0,12,0,0"
                           Foreground="#FCA5A5"
                           FontSize="14" />
                <Button Margin="0,24,0,0"
                        Height="44"
                        Content="解锁"
                        Click="OnUnlockClick" />
                <TextBlock Margin="0,18,0,0"
                           Text="Esc 和 Alt+F4 已拦截。要结束程序请在任务管理器里关闭 MVP 进程。"
                           Foreground="#94A3B8"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
